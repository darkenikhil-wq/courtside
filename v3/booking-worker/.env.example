PORT=8787
BOOKING_WORKER_TOKEN=dev-local-token

# Use your WebTrac account for the first private POC.
# Do not commit a real .env file.
WEBTRAC_USERNAME=
WEBTRAC_PASSWORD=

# Keep true until we explicitly confirm the final checkout/payment behavior.
DRY_RUN=true

# WebTrac/Cloudflare is much more reliable in a visible local browser.
HEADLESS=false
SLOW_MO_MS=0

# Optional. On macOS this avoids downloading Playwright's bundled Chromium.
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional cloud escape hatch. Set this to a managed browser WebSocket endpoint
# when WebTrac blocks the worker host's local Chromium/IP profile.
# PLAYWRIGHT_CONNECT_MODE can be "cdp" or "playwright"; most hosted Chrome
# endpoints use "cdp".
PLAYWRIGHT_WS_ENDPOINT=
REMOTE_BROWSER_ENABLED=false
PLAYWRIGHT_CONNECT_MODE=cdp
PLAYWRIGHT_CONNECT_TIMEOUT_MS=60000
PLAYWRIGHT_CONNECT_ATTEMPTS=3

# Browserless shortcut. If PLAYWRIGHT_WS_ENDPOINT is blank, the worker can build
# wss://production-<region>.browserless.io/<route>?token=...
BROWSERLESS_TOKEN=
BROWSERLESS_ENABLED=false
BROWSERLESS_REGION=sfo
BROWSERLESS_ROUTE=chrome
BROWSERLESS_ALLOW_STEALTH=false
BROWSERLESS_STEALTH=false
BROWSERLESS_TIMEOUT_SECONDS=300
BROWSERLESS_PROXY_ENABLED=false
BROWSERLESS_PROXY=
BROWSERLESS_PROXY_COUNTRY=
BROWSERLESS_PROXY_CITY=
BROWSERLESS_PROXY_STICKY=
BROWSERLESS_PROXY_PRESET=

# Keeps Playwright temporary files inside the worker where they can be cleared.
PLAYWRIGHT_ARTIFACT_DIR=.playwright-artifacts

# The worker owns one reservation at a time. Clear stale WebTrac cart items
# before adding a new court so old tests cannot be paid by mistake.
WEBTRAC_CLEAR_CART_BEFORE_RESERVE=true

# Courtside-controlled WebTrac payment profile.
# Keep these local/private. Never commit a real .env file.
WEBTRAC_BILL_FIRST_NAME=
WEBTRAC_BILL_LAST_NAME=
WEBTRAC_BILL_PHONE=
WEBTRAC_BILL_EMAIL=
WEBTRAC_CARD_NAME=
WEBTRAC_BILL_ADDRESS1=
WEBTRAC_BILL_POSTAL_CODE=
WEBTRAC_CARD_NUMBER=
WEBTRAC_CARD_EXP=
WEBTRAC_CARD_CVC=

# Final WebTrac payment stays off unless explicitly enabled.
ALLOW_WEBTRAC_FINAL_PAYMENT=false
WEBTRAC_RECAPTCHA_WAIT_MS=120000
