PORT=8787
BOOKING_WORKER_TOKEN=dev-local-token

# Use your WebTrac account for the first private POC.
# Do not commit a real .env file.
WEBTRAC_USERNAME=
WEBTRAC_PASSWORD=

# Keep true until we explicitly confirm the final checkout/payment behavior.
DRY_RUN=true

# WebTrac/Cloudflare is much more reliable in a visible local browser.
HEADLESS=false
SLOW_MO_MS=0

# Optional. On macOS this avoids downloading Playwright's bundled Chromium.
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Keeps Playwright temporary files inside the worker where they can be cleared.
PLAYWRIGHT_ARTIFACT_DIR=.playwright-artifacts
